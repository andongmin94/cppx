{
  "name": "cppx",
  "version": "0.1.0",
  "description": "Cargo-like C++ workflow with native host support and Electron UI",
  "main": "./out/main/index.js",
  "author": "cppx",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-electron-vite.mjs dev",
    "build": "electron-vite build",
    "preview": "node ./scripts/run-electron-vite.mjs preview",
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/run-tests.mjs",
    "test:ci": "node ./scripts/run-tests-ci.mjs",
    "smoke:ci": "node ./scripts/run-smoke-ci.mjs",
    "smoke:native": "tsx ./scripts/smoke-native-host.ts",
    "cppx": "tsx src/main/cli.ts"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.1",
    "lucide-react": "^0.545.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "electron": "^37.3.1",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
